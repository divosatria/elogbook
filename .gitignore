# ==============================================================================
# E-Logbook Monorepo .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Environment & Secrets
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
deploy-config.json
.deployment

# ------------------------------------------------------------------------------
# 2. Node.js (Backend & Frontend)
# ------------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pids/
*.pid
*.seed
*.pid.lock
coverage/
*.lcov
.nyc_output
.npm
.eslintcache
.node_repl_history
dist/
build/
*.tsbuildinfo
.next
.nuxt
.vuepress/dist
.serverless/
.fusebox/
.dynamodb/
ecosystem.config.js

# ------------------------------------------------------------------------------
# 3. Flutter & Dart (mobile_e-logbook & desktop)
# ------------------------------------------------------------------------------
.dart_tool/
.packages
.pub-cache/
.pub/
build/
*.dart.js
*.js.deps
*.js.map
*.info
*.js.tar.gz
*.symbols

# Android/iOS/Web/Windows/Linux/macOS Build outputs
android/app/src/main/java/io/flutter/plugins/GeneratedPluginRegistrant.java
android/local.properties
android/key.properties
android/**/*.apk
android/**/*.aab
ios/Flutter/App.framework
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/Generated.xcconfig
ios/Flutter/app.flx
ios/Flutter/app.zip
ios/Flutter/flutter_assets/
ios/Flutter/flutter_export_environment.sh
ios/Pods/
ios/.symlinks/
macos/Flutter/GeneratedPluginRegistrant.swift
macos/Flutter/ephemeral/
macos/Pods/
windows/flutter/ephemeral/
windows/flutter/generated_plugin_registrant.cc
linux/flutter/ephemeral/

# Exceptions to Flutter
!**/ios/Flutter/AppFrameworkInfo.plist

# ------------------------------------------------------------------------------
# 4. Python (AI Model - model-prediksi)
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
ENV/
env.bak/
venv.bak/
.pytest_cache/
.mypy_cache/
.tox/
.coverage
.coverage.*
nosetests.xml
coverage.xml
*.mo
*.pot

# ------------------------------------------------------------------------------
# 5. OS Generated Files
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ------------------------------------------------------------------------------
# 6. IDEs & Editors
# ------------------------------------------------------------------------------
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project
.directory

# ------------------------------------------------------------------------------
# 7. Database & Storage
# ------------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db

# ------------------------------------------------------------------------------
# 8. Uploads, User Content, & Temp Files
# ------------------------------------------------------------------------------
uploads/
public/uploads/
backend/uploads/
tmp/
temp/
.local/
local/
logs/
*.log
*.backup
*.bak
backup_*/
data/
!frontend/src/assets/data/
*.json.backup
test-results/

# ------------------------------------------------------------------------------
# 9. AI Model Checkpoints & Large Data
# ------------------------------------------------------------------------------
backend/model-prediksi/model/*.pt
backend/model-prediksi/model/*.pth
backend/model-prediksi/model/*.onnx
backend/model-prediksi/model/*.tflite
*.h5
*.keras