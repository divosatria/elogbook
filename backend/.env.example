# Database MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=e_logbook
DB_USER=root
DB_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here-change-this-in-production
JWT_EXPIRE=7d

# Default Admin Password (for fallback mode)
DEFAULT_ADMIN_PASSWORD=admin123

# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Swagger / API docs access
# SWAGGER_PUBLIC=true         # set to true to allow docs from any host (not recommended in production)
# SWAGGER_BASIC_USER=admin    # basic auth username for /api-docs (optional)
# SWAGGER_BASIC_PASS=secret   # basic auth password for /api-docs (optional)

# Mobile login rate limit
# MOBILE_RATE_LIMIT_MAX=10    # max attempts per 15-minute window (default 10)

# Weather API
WEATHER_API_URL=https://api.openweathermap.org/data/2.5
WEATHER_API_KEY=your-openweather-api-key

# Emergency Notifications (Twilio)
# Uncomment and configure these for SMS/WhatsApp emergency alerts
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+1234567890
# TWILIO_WHATSAPP_NUMBER=+14155238886

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads