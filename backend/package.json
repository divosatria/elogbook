{
  "name": "e-logbook-backend",
  "version": "2.0.0",
  "description": "E-Logbook Maritime - Digital management platform for Indonesian fishing industry",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:prod": "NODE_ENV=production node server.js",
    "dev": "nodemon server.js",
    "dev:clean": "NODE_ENV=development LOG_LEVEL=info nodemon server.js",
    "dev:mobile": "NODE_ENV=development LOG_LEVEL=debug nodemon server.js",
    "start:ai": "cd model-prediksi && .\\.venv\\Scripts\\activate && python api.py",
    "setup:mobile": "node -e \"console.log('🚀 Run setup-mobile-dev.bat (Windows) or setup-mobile-dev.sh (Linux/Mac) to configure mobile development')\"",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "setup": "node setupDatabase.js",
    "setup:prod": "NODE_ENV=production node setupDatabase.js",
    "create-admin": "node createAdmin.js",
    "create-mobile-users": "node createMobileTestUsers.js",
    "migrate": "node migrateVesselFields.js",
    "migrate-vessel-id": "node addVesselIdMigration.js",
    "seed": "node seedTestData.js",
    "check-db": "node checkDatabase.js",
    "build": "echo 'No build step required for backend'",
    "clean": "rm -rf node_modules package-lock.json",
    "security:audit": "npm audit",
    "security:fix": "npm audit fix",
    "security:check": "npm audit --audit-level=moderate",
    "security:report": "npm audit --json > security-report.json",
    "generate:secret": "node -e \"console.log('JWT_SECRET=' + require('crypto').randomBytes(32).toString('hex'))\"",
    "logs": "pm2 logs e-logbook-maritime",
    "restart": "pm2 restart e-logbook-maritime",
    "stop": "pm2 stop e-logbook-maritime",
    "status": "pm2 status"
  },
  "keywords": [
    "nodejs",
    "express",
    "mysql",
    "sequelize",
    "maritime",
    "fishing",
    "logbook",
    "vessel-management",
    "gps-tracking",
    "emergency-system"
  ],
  "author": "E-Logbook Maritime Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csurf": "^1.2.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.0.1",
    "form-data": "^4.0.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.16.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.12",
    "pdfkit": "^0.17.2",
    "sequelize": "^6.37.7",
    "socket.io": "^4.6.1",
    "sqlite3": "^6.0.1",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^4.23.0",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-repo/e-logbook-maritime.git"
  },
  "bugs": {
    "url": "https://github.com/your-repo/e-logbook-maritime/issues"
  },
  "homepage": "https://github.com/your-repo/e-logbook-maritime#readme"
}
